# Bolna AI Configuration
BOLNA_API_KEY=your_bolna_api_key_here
BOLNA_API_BASE=https://api.bolna.ai

# Your Platform Pricing (markup over Bolna's cost)
PLATFORM_MARKUP_PER_MIN=0.02
BOLNA_BASE_COST_PER_MIN=0.02

# Webhook URL (your server's public URL for receiving Bolna webhooks)
WEBHOOK_BASE_URL=https://your-domain.com

# MongoDB Configuration (for call insights and lead scoring)
MONGODB_URI=mongodb://localhost:27017/voice-campaign-insights

# Server
PORT=3001
NODE_ENV=production

# JWT Secret for auth (change this!)
JWT_SECRET=your_super_secret_jwt_key_change_this
